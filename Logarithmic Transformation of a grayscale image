from google.colab.patches import cv2_imshow
import numpy as np
import cv2
import math

img = cv2.imread('lena.jpg', cv2.IMREAD_GRAYSCALE)
cv2_imshow(img)
out=img.copy()  # Creates a copy of the original image to store the transformed output.

print(img.max()) # prints pixel intensity (brightness or color level)
print(img.min())

#print(img.shape)  # pixel value of the image
for i in range(img.shape[0]):   # Rows
  for j in range(img.shape[1]): # Columns
    a = img.item[i,j]         # input 
    b = math.log(a+1, 2) #Formula, Applies base-2 logarithm to (a + 1).
    c = 31               # scaling constant
    out[i,j] = c*b

cv2_imshow(out) # Logarithmically transformed image

cv2_imshow(img) 

cv2.waitKey(0)
cv2.destroyAllWindows()
