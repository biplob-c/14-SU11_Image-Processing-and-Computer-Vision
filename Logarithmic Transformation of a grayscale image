from google.colab.patches import cv2_imshow
import numpy as np
import cv2
import math

img = cv2.imread('lena.jpg', cv2.IMREAD_GRAYSCALE)
cv2_imshow(img)
out=img.copy()

print(img.max())
print(img.min())

#print(img.shape)
for i in range(img.shape[0]):
    for j in range(img.shape[1]):
        a = img.item(i,j)
        b=math.log(a+1,2)
        c=31
        out[i,j] = c*b

cv2_imshow(out)

cv2_imshow(img)

cv2.waitKey(0)
cv2.destroyAllWindows()
